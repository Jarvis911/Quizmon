// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  username String?
  email    String  @unique
  password String?
  googleId String? @unique

  avatarUrl String?
  bio       String?
  isAdmin   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizzes           Quiz[]
  quizRatings       QuizRating[]
  matchs            Match[]
  matchResults      MatchResult[]
  matchParticipants MatchParticipant[]
  aiGenerationJobs  AIGenerationJob[]
  agentChatSessions AgentChatSession[]
  systemReports     SystemReport[]

  classrooms        Classroom[]
  classroomMembers  ClassroomMember[]
  expectedStudents  ExpectedStudent[]
  notifications     Notification[]

  // SaaS: Organization memberships
  organizationMembers OrganizationMember[]
}

model QuizCategory {
  id   Int    @id @default(autoincrement())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizzes Quiz[]
}

model Quiz {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  image       String?
  isPublic    Boolean @default(false)

  creatorId  Int
  creator    User         @relation(fields: [creatorId], references: [id])
  categoryId Int
  category   QuizCategory @relation(fields: [categoryId], references: [id])

  // SaaS: Organization ownership
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions        Question[]
  quizRatings      QuizRating[]
  matchs           Match[]
  aiGenerationJobs AIGenerationJob[]

  @@index([organizationId])
}

model QuizRating {
  id     Int     @id @default(autoincrement())
  rating Int
  text   String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId Int
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ImageEffect {
  NONE
  BLUR_TO_CLEAR
  ZOOM_IN
  ZOOM_OUT
}

model QuestionMedia {
  id        Int       @id() @default(autoincrement())
  type      MediaType
  url       String
  startTime Int?
  duration  Int?
  effect    ImageEffect? @default(NONE)
  zoomX     Float?       @default(0.5)
  zoomY     Float?       @default(0.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionId Int
  question   Question? @relation(fields: [questionId], references: [id])
}

enum QuestionType {
  BUTTONS
  CHECKBOXES
  REORDER
  TYPEANSWER
  LOCATION
}

model Question {
  id   Int          @id @default(autoincrement())
  text String
  type QuestionType
  data Json?        // Type-specific data (range config, correct answer, location coords, etc.)

  quizId Int
  quiz   Quiz @relation(fields: [quizId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options         QuestionOption[]
  media           QuestionMedia[]
  matchAnswers    MatchAnswer[]
  aiGeneratedFrom AIGeneratedQuestion?
}

model QuestionOption {
  id        Int      @id @default(autoincrement())
  text      String
  isCorrect Boolean? @default(false) // Button, Checkbox
  order     Int? // Reorder

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId])
}

model Match {
  id        Int       @id @default(autoincrement())
  pin       String?   @unique // 6-digit PIN for joining
  startTime DateTime?
  endTime   DateTime?

  // Host configuration
  timePerQuestion Int? // seconds per question (null = unlimited)
  backgroundUrl   String? // custom background image/video URL
  musicUrl        String? // background music URL

  quizId Int
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  hostId Int
  host   User @relation(fields: [hostId], references: [id], onDelete: Cascade)

  // SaaS: Organization ownership
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  mode        MatchMode  @default(REALTIME)
  deadline    DateTime? // Hạn chót nộp bài
  classroomId Int?      // Giao cho một lớp cụ thể
  classroom   Classroom? @relation(fields: [classroomId], references: [id])
  strictMode  Boolean    @default(false) // Chống gian lận: rời khỏi tab trình duyệt là bị trừ điểm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MatchParticipant[]
  matchResults MatchResult[]

  @@index([organizationId])
}

model MatchResult {
  id    Int  @id @default(autoincrement())
  score Int?

  userId  Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId Int
  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([matchId])
}

// ==================== NEW MODELS ====================

// Match Participant - User customization per match
model MatchParticipant {
  id Int @id @default(autoincrement())

  // User customization for this match
  displayName String
  avatarUrl   String?

  matchId Int
  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  Int? // nullable for guest users
  user    User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  startTime DateTime? // Lúc học sinh bấm "Bắt đầu làm bài"
  endTime   DateTime? // Lúc học sinh Submit bài hoặc hết giờ cá nhân
  status    ParticipantStatus @default(NOT_STARTED)

  answers MatchAnswer[]

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
}

// Match Answer - Detailed answer tracking for reports
model MatchAnswer {
  id Int @id @default(autoincrement())

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  participantId Int
  participant   MatchParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  // Answer data
  answerData Json // stores the user's answer (flexible for different question types)
  isCorrect  Boolean
  score      Int // points earned for this answer
  timeTaken  Int? // milliseconds to answer

  answeredAt DateTime @default(now())

  @@unique([participantId, questionId])
  @@index([participantId])
  @@index([questionId])
}

// ==================== AI GENERATION MODELS ====================

enum AIGenerationStatus {
  PENDING // Job created, waiting to process
  PROCESSING // AI is generating questions
  COMPLETED // Generation complete, awaiting review
  APPROVED // User approved all questions
  FAILED // Generation failed
}

enum AIQuestionStatus {
  PENDING // Awaiting user review
  APPROVED // User approved this question
  REJECTED // User rejected, needs regeneration
  REGENERATING // AI is regenerating this question
}

// AI Generation Job - Tracks AI question generation jobs
model AIGenerationJob {
  id Int @id @default(autoincrement())

  // Input configuration
  instruction  String? // text instruction from user
  pdfUrl       String? // uploaded PDF URL
  imageUrls    String[] // uploaded image filenames
  targetQuizId Int? // if adding to existing quiz
  targetQuiz   Quiz?   @relation(fields: [targetQuizId], references: [id], onDelete: SetNull)

  // AI suggestions for new quiz
  suggestedTitle         String?
  suggestedDescription   String?
  suggestedCategoryId    Int?
  suggestedCoverImageUrl String? // AI-generated cover, uploaded to blob storage

  // Job metadata
  status        AIGenerationStatus @default(PENDING)
  questionCount Int                @default(10)
  errorMessage  String?
  totalTokens   Int?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SaaS: Organization ownership
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedQuestions AIGeneratedQuestion[]

  @@index([userId])
  @@index([status])
  @@index([organizationId])
}

// AI Agent Chat Models for persistent history
model AgentChatSession {
  id    Int     @id @default(autoincrement())
  title String? @default("Cuộc hội thoại mới")

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AgentChatMessage[]

  @@index([userId])
}

model AgentChatMessage {
  id   Int    @id @default(autoincrement())
  role String // "user" or "model"
  text String @db.Text

  sessionId Int
  session   AgentChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sessionId])
}

// AI Generated Question - Individual AI-generated questions pending review
model AIGeneratedQuestion {
  id Int @id @default(autoincrement())

  jobId Int
  job   AIGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Generated content
  questionText String
  questionType QuestionType
  optionsData  Json // stores options, correct answers, etc.

  // AI-generated illustration (optional)
  generatedImageUrl String?
  imageEffect       ImageEffect @default(NONE)

  // Review status
  status            AIQuestionStatus @default(PENDING)
  userFeedback      String? // user's feedback for regeneration
  regenerationCount Int              @default(0)

  // If approved and added to quiz
  finalQuestionId Int?      @unique
  finalQuestion   Question? @relation(fields: [finalQuestionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
}

// ==================== LMS & CLASSROOM MODELS ====================

enum MatchMode {
  REALTIME   // Chơi trực tiếp, host điều khiển
  HOMEWORK   // Bài tập về nhà, Async
}

enum ParticipantStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  LATE
}

enum ClassroomRole {
  TEACHER
  STUDENT
}

enum MemberStatus {
  PENDING   // Chờ giáo viên duyệt
  APPROVED  // Đã được duyệt
  REJECTED  // Bị từ chối
}

model Classroom {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  joinCode    String   @unique // Mã code 6 chữ số để học sinh tự join
  inviteLink  String   @unique // Link mời trực tiếp

  teacherId   Int
  teacher     User     @relation(fields: [teacherId], references: [id])

  // SaaS: Organization ownership
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  members          ClassroomMember[]
  expectedStudents ExpectedStudent[]
  assignments      Match[]  // Các Quiz được giao cho lớp này

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
}

model ClassroomMember {
  id          Int          @id @default(autoincrement())
  role        ClassroomRole @default(STUDENT)
  status      MemberStatus  @default(PENDING) // PENDING cho đến khi giáo viên approve

  classroomId Int
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinDate    DateTime @default(now())

  @@unique([classroomId, userId])
  @@index([classroomId])
  @@index([userId])
}

// Danh sách học sinh dự kiến (import từ file PDF của nhà trường)
model ExpectedStudent {
  id          Int      @id @default(autoincrement())
  name        String
  studentCode String?  // Mã số học sinh
  email       String?  // Email dự kiến

  classroomId Int
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  // Link đến tài khoản thực tế nếu đã tham gia
  matchedUserId Int?
  matchedUser   User?    @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([classroomId])
}

// ==================== NOTIFICATION MODELS ====================

model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  type      String   // e.g., "HOMEWORK_ASSIGNED", "CLASSROOM_JOINED"
  isRead    Boolean  @default(false)
  link      String?  // Optional URL to redirect when clicked

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ==================== SAAS MULTI-TENANT MODELS ====================

enum OrganizationRole {
  OWNER
  ADMIN
  TEACHER
  MEMBER
}

enum PlanType {
  FREE
  TEACHER_PRO
  SCHOOL
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum PaymentStatus {
  PAY_PENDING
  COMPLETED
  PAY_FAILED
  REFUNDED
}

enum PaymentMethod {
  MOMO
  VNPAY
  STRIPE
  MOCK
}

enum FeatureKey {
  AI_GENERATION
  UNLIMITED_MATCHES
  ADVANCED_ANALYTICS
  UNLIMITED_CLASSROOMS
  MAX_CLASSROOMS
  MAX_STUDENTS_PER_CLASSROOM
  MAX_PLAYERS_PER_MATCH
  CUSTOM_BRANDING
  PRIORITY_SUPPORT
}

model Organization {
  id      Int    @id @default(autoincrement())
  name    String
  slug    String @unique
  logoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       OrganizationMember[]
  quizzes       Quiz[]
  classrooms    Classroom[]
  matches       Match[]
  aiJobs        AIGenerationJob[]
  subscriptions Subscription[]
  payments      Payment[]
  usageMetrics  UsageMetric[]
}

model OrganizationMember {
  id   Int              @id @default(autoincrement())
  role OrganizationRole @default(MEMBER)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Plan {
  id           Int      @id @default(autoincrement())
  type         PlanType @unique
  name         String
  description  String?
  priceMonthly Float    @default(0)
  priceYearly  Float    @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]
  promotions    Promotion[]
}

model PlanFeature {
  id         Int        @id @default(autoincrement())
  featureKey FeatureKey
  limit      Int? // null = unlimited, number = max allowed
  enabled    Boolean    @default(true)

  planId Int
  plan   Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([planId])
}

model Subscription {
  id           Int                @id @default(autoincrement())
  status       SubscriptionStatus @default(ACTIVE)
  billingCycle BillingCycle       @default(MONTHLY)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  canceledAt  DateTime?
  trialEndsAt DateTime?

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         Int
  plan           Plan         @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([planId])
  @@index([status])
}

model Payment {
  id            Int           @id @default(autoincrement())
  amount        Float
  currency      String        @default("USD")
  status        PaymentStatus @default(PAY_PENDING)
  paymentMethod PaymentMethod @default(MOCK)

  externalId  String? // Gateway transaction ID (MoMo orderId, Stripe session ID, etc.)
  description String?

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([status])
}

model UsageMetric {
  id    Int    @id @default(autoincrement())
  key   String // "matches_hosted", "ai_generations", "students_joined", "quizzes_created"
  value Int    @default(0)

  periodStart DateTime
  periodEnd   DateTime

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, key, periodStart])
  @@index([organizationId])
}




// ==================== ADMIN & SYSTEM MODELS ====================

model AIModelConfig {
  id          Int      @id @default(autoincrement())
  featureName String   @unique // e.g., 'QUIZ_GENERATION', 'AGENT_CHAT'
  modelName   String   // e.g., 'gemini-2.5-flash', 'gemini-3.0-flash'
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

enum ReportType {
  QUIZ
  USER
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model SystemReport {
  id         Int          @id @default(autoincrement())
  reportType ReportType
  targetId   Int          // The ID of the Quiz or User being reported
  reason     String       // User's description of the issue

  status     ReportStatus @default(PENDING)

  reporterId Int
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([status])
}

// ==================== PROMOTION & CAMPAIGN MODELS ====================

model Promotion {
  id          Int      @id @default(autoincrement())
  title       String   // e.g. "Gói Giáo Viên Pro - MIỄN PHÍ!"
  subtitle    String?  // e.g. "Ưu đãi áp dụng đến hết tháng 9"
  description String?

  // Liên kết gói được khuyến mãi
  planId      Int
  plan        Plan     @relation(fields: [planId], references: [id])

  // Giá sau khuyến mãi (0 = miễn phí)
  discountedPriceMonthly Float @default(0)
  discountedPriceYearly  Float @default(0)

  // Thời gian hiệu lực
  expiresAt   DateTime

  // Trạng thái banner
  isActive    Boolean  @default(true)   // Promotion còn hợp lệ (chưa hết hạn, chưa bị xóa)
  isPublished Boolean  @default(false)  // Đang hiển thị trên banner

  // Style banner
  bannerColor String?  @default("#0078D4")
  badgeText   String?  @default("KHUYẾN MÃI") // Badge label trên plan card

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([isActive])
  @@index([planId])
}
